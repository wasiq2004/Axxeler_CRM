PORT=4000
CLIENT_ORIGIN=http://localhost:3000
API_PROXY_TARGET=http://localhost:4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ziya_crm
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REDIS_URL=redis://localhost:6379
ENABLE_WORKERS=false

# Resend
RESEND_API_KEY=
EMAIL_FROM=ZIYA CRM <noreply@example.com>

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Meta / WhatsApp Cloud API
# Create an app at https://developers.facebook.com → Products → Facebook Login + Marketing API
# Required permissions: ads_read, leads_retrieval, pages_read_engagement, pages_show_list
META_APP_ID=
META_APP_SECRET=
# Add http://localhost:4000/api/meta/callback as a Valid OAuth Redirect URI in your Meta App settings
META_REDIRECT_URI=http://localhost:4000/api/meta/callback
# A secret string you choose — paste into Meta Webhooks config → Verify Token
META_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_VERSION=v20.0

UPLOAD_DIR=uploads
