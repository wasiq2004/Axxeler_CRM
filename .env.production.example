# ── Subdomain (no https://, just the hostname) ─────────────────────────────
DOMAIN=crm.yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────
DB_USER=axxeler
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=axxeler_crm

# ── Auth secrets (generate with: openssl rand -hex 32) ────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_2
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── Email (Resend — optional) ──────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Axxeler CRM <noreply@yourdomain.com>

# ── Meta / WhatsApp (optional) ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# ── Razorpay (optional) ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Gemini AI (optional, injected into the frontend build) ─────────────────
GEMINI_API_KEY=
