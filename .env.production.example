# ── Database ───────────────────────────────────────────────────────────────
DB_USER=axxeler
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=axxeler_crm

# ── Auth ───────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_2
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── App URLs ───────────────────────────────────────────────────────────────
# Set this to your subdomain (used for CORS)
CLIENT_ORIGIN=https://crm.yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Axxeler CRM <noreply@yourdomain.com>

# ── Meta / WhatsApp (optional) ─────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://crm.yourdomain.com/api/meta/callback
META_WEBHOOK_VERIFY_TOKEN=

# ── Razorpay (optional) ────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Gemini AI (optional, baked into frontend build) ────────────────────────
GEMINI_API_KEY=
