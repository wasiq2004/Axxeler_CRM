FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY server/ ./server/
COPY prisma/ ./prisma/

RUN node_modules/.bin/prisma generate
# Fail the image build if the server has type errors (no more silent `|| true`).
RUN node_modules/.bin/tsc -p server/tsconfig.json

COPY server/entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

EXPOSE 4000
ENTRYPOINT ["./entrypoint.sh"]
