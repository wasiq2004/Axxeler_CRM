FROM node:20-alpine
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY server/ ./server/
COPY prisma/ ./prisma/

RUN node_modules/.bin/prisma generate
RUN node_modules/.bin/tsc -p server/tsconfig.json || true

COPY server/entrypoint.sh ./entrypoint.sh
RUN chmod +x ./entrypoint.sh

EXPOSE 4000
ENTRYPOINT ["./entrypoint.sh"]
